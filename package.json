{
  "name": "cyber-sahiyogi-monorepo",
  "version": "1.0.0",
  "description": "Unified J.A.R.V.I.S. Assistant",
  "scripts": {
    "install-all": "npm install && cd backend && npm install && cd ../frountend && npm install",
    "dev": "npm-run-all --parallel backend frontend",
    "backend": "npm run dev --prefix backend",
    "frontend": "npm start --prefix frountend",
    "build-frontend": "npm run build --prefix frountend",
    "start": "npm start --prefix backend"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "npm-run-all": "^4.1.5"
  }
}
